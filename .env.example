# ─── FindMySpare Backend — Environment Variables ────────────────────────────
# Copy to .env for local dev. Never commit .env to git.
# Production values are set in the Render dashboard (Settings → Environment).

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── CORS ───────────────────────────────────────────────────────────────────
# In production set to your live frontend URL: https://findmyspare.com
FRONTEND_URL=http://localhost:3000

# Optional comma-separated list of extra prod origins (preview deploys, custom domains).
# Example: PROD_EXTRA_ORIGINS=https://www.findmyspare.com,https://findmyspare.vercel.app
PROD_EXTRA_ORIGINS=

# ─── Database (Nhost PostgreSQL) ─────────────────────────────────────────────
# Find in Nhost dashboard → Project → Database → Connection string
# Format: postgresql://user:pass@host:port/db?sslmode=require
DATABASE_URL=postgresql://postgres:password@db.xxxx.eu-central-1.nhost.run:5432/postgres?sslmode=require

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-use-openssl-rand-base64-64

# Access-token TTL (seconds). Default 900 (15m). Admin sessions are auto-shortened to 600 (10m).
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800   # 7d

# ─── Nhost Storage ───────────────────────────────────────────────────────────
# Nhost dashboard → Project → Settings → Secrets
NHOST_SUBDOMAIN=xxxxxxxxxxxx
NHOST_REGION=eu-central-1
NHOST_ADMIN_SECRET=change-me-nhost-admin-secret
# Default bucket is "default" — change only if you created a custom bucket
NHOST_BUCKET_ID=default

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Sign up at https://resend.com. Free tier: 3,000 emails/mo, 100/day.
# Add a verified sending domain (findmyspare.com) before going live.
RESEND_API_KEY=re_change_me
RESEND_FROM="FindMySpare <noreply@findmyspare.com>"

# ─── WhatsApp OTP (Meta Cloud API) — optional, dormant in v1 ─────────────────
# Used to deliver the 6-digit login code via WhatsApp. We own the code; this
# only delivers it. Get these from developers.facebook.com → your app → WhatsApp.
WHATSAPP_TOKEN=EAAG...                      # access token (temp 24h, or system-user token for prod)
WHATSAPP_PHONE_NUMBER_ID=123456789012345    # sender Phone number ID (NOT the number itself)
WHATSAPP_OTP_TEMPLATE=otp                   # approved authentication template name
WHATSAPP_OTP_LANG=en_US                     # template language code
# Set to "true" only if your template has NO copy-code button.
WHATSAPP_OTP_NO_BUTTON=false

# ─── GSTIN verification (RapidAPI — free tier, no card) ──────────────────────
# Live GST registration status + legal name for supplier review.
# 1. Sign up at https://rapidapi.com  2. Subscribe to a GST-verification API
#    (e.g. "GST Insights API" / "GSTIN Verification") on its free plan
# 3. Copy the values from the API's "Code Snippets" panel.
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_GST_HOST=gst-insights-api.p.rapidapi.com
# Full endpoint with {gstin} placeholder — copy the path from the API docs:
RAPIDAPI_GST_URL=https://gst-insights-api.p.rapidapi.com/getGSTDetailsUsingGST/{gstin}
RAPIDAPI_GST_METHOD=GET
# Only for POST-style APIs: JSON body template, {gstin} placeholder
# RAPIDAPI_GST_BODY={"gstin":"{gstin}"}
