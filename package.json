{
  "name": "findmyspare-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "bun --env-file=.env x drizzle-kit generate",
    "db:push": "bun --env-file=.env x drizzle-kit push",
    "db:studio": "bun --env-file=.env x drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/jwt": "^1.2.0",
    "@elysiajs/swagger": "^1.2.0",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.2.25",
    "postgres": "^3.4.8",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.0",
    "@types/bun": "latest"
  }
}
