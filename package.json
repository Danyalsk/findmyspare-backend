{
  "name": "findmyspare-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=.env run --watch src/index.ts",
    "start": "bun --env-file=.env run src/index.ts",
    "db:generate": "bun --env-file=.env x drizzle-kit generate",
    "db:push": "bun --env-file=.env x drizzle-kit push",
    "db:studio": "bun --env-file=.env x drizzle-kit studio",
    "db:seed": "bun --env-file=.env run src/scripts/seed.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/jwt": "^1.2.0",
    "@elysiajs/swagger": "^1.2.0",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.2",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.2.25",
    "firebase": "^12.13.0",
    "postgres": "^3.4.8",
    "resend": "^6.12.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.0"
  }
}
